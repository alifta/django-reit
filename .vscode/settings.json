{
    "beautify.language": {
        "html": [
            "django-html"
        ]
    },
    "[django-html]": {
        "editor.formatOnSave": false,
        "editor.defaultFormatter": "HookyQR.beautify"
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "python.formatting.provider": "none",
    "cSpell.words": [
        "apikey",
        "sendgrid",
        "SINGLEFAMILY"
    ]
}